<MudDialog>
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Style="min-width: 0;">
            <MudIconButton Icon="@Icons.Material.Filled.Close"
                           Color="Color.Default"
                           Size="Size.Small"
                           OnClick="Close"
                           title="Close viewer" />
            <MudStack Spacing="0" Style="min-width: 0;">
                <MudText Typo="Typo.h6">@Title</MudText>
                @if (!string.IsNullOrWhiteSpace(Subtitle))
                {
                    <MudText Typo="Typo.caption" Style="display: block; max-width: min(72rem, 78vw); overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@Subtitle</MudText>
                }
            </MudStack>
        </MudStack>
    </TitleContent>
    <DialogContent>
        @if (string.IsNullOrWhiteSpace(ViewerUrl))
        {
            <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">Viewer URL missing.</MudAlert>
        }
        else
        {
            <div style="height: calc(100dvh - 8rem); min-height: 24rem; overflow: hidden; background: #05080c; border: 1px solid var(--mud-palette-lines-default); border-radius: var(--mud-default-borderradius);">
                <iframe style="display: block; width: 100%; height: 100%; border: 0; background: #05080c;"
                        src="@ViewerUrl"
                        title="@Title"
                        allow="fullscreen"></iframe>
            </div>
        }
    </DialogContent>
</MudDialog>

@code
{
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public string ViewerUrl { get; set; } = string.Empty;

    [Parameter]
    public string Title { get; set; } = "Grid Viewer";

    [Parameter]
    public string Subtitle { get; set; } = string.Empty;

    private void Close()
    {
        MudDialog.Close();
    }
}
