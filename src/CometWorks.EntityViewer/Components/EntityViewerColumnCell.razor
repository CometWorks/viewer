@inject IDialogService DialogService

<MudTd DataLabel="" Class="quasar-actions-column">
    <span @onclick:stopPropagation="true">
        <MudTooltip Text="@TooltipText">
            <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                           Color="Color.Primary"
                           Size="Size.Small"
                           Disabled="@(!CanOpenViewer)"
                           OnClick="OpenViewerAsync" />
        </MudTooltip>
    </span>
</MudTd>

@code
{
    private const string PluginViewerPath = "/_quasar/plugins/cometworks.entityviewer/index.html";
    private const string PluginAssetSetupModulePath = "/_quasar/plugins/cometworks.entityviewer/viewer-asset-setup.js";
    private const string PluginAssetSetupApiBasePath = "/_quasar/plugins/cometworks.entityviewer/api/assets";

    [Parameter]
    public string? AgentId { get; set; }

    [Parameter]
    public string? ServerName { get; set; }

    [Parameter]
    public long EntityId { get; set; }

    [Parameter]
    public string? EntityType { get; set; }

    [Parameter]
    public string? EntitySubType { get; set; }

    [Parameter]
    public string? EntityDisplayName { get; set; }

    [Parameter]
    public ulong? OwnerSteamId { get; set; }

    [Parameter]
    public bool CanViewEntity { get; set; }

    [Parameter]
    public string? ViewerUrl { get; set; }

    [Parameter]
    public string AssetSetupModuleUrl { get; set; } = PluginAssetSetupModulePath;

    [Parameter]
    public string AssetSetupApiBasePath { get; set; } = PluginAssetSetupApiBasePath;

    [Parameter]
    public bool AutoOpenAssetSetup { get; set; } = true;

    [Parameter]
    public EventCallback OpenEntityViewer { get; set; }

    private bool CanOpenViewer => CanViewEntity
                                  && (!string.IsNullOrWhiteSpace(AgentId)
                                      || !string.IsNullOrWhiteSpace(ViewerUrl)
                                      || OpenEntityViewer.HasDelegate);

    private string TooltipText => CanOpenViewer
        ? "Open viewer"
        : "Entity is not viewable";

    private async Task OpenViewerAsync()
    {
        if (!CanOpenViewer)
            return;

        var viewerUrl = BuildPluginViewerUrl() ?? ViewerUrl;
        if (!string.IsNullOrWhiteSpace(viewerUrl))
        {
            var title = string.IsNullOrWhiteSpace(EntityDisplayName)
                ? $"Entity {EntityId}"
                : EntityDisplayName;
            var subtitle = $"{ServerName ?? AgentId ?? "Unknown server"} - {EntityType ?? "Entity"} #{EntityId}";
            var parameters = new DialogParameters
            {
                [nameof(EntityViewerDialog.ViewerUrl)] = viewerUrl,
                [nameof(EntityViewerDialog.Title)] = title,
                [nameof(EntityViewerDialog.Subtitle)] = subtitle,
                [nameof(EntityViewerDialog.AssetSetupModuleUrl)] = AssetSetupModuleUrl,
                [nameof(EntityViewerDialog.AssetSetupApiBasePath)] = AssetSetupApiBasePath,
                [nameof(EntityViewerDialog.AutoOpenAssetSetup)] = AutoOpenAssetSetup,
            };
            var options = new DialogOptions
            {
                CloseOnEscapeKey = true,
                FullScreen = true,
            };

            await DialogService.ShowAsync<EntityViewerDialog>(title, parameters, options);
            return;
        }

        if (OpenEntityViewer.HasDelegate)
            await OpenEntityViewer.InvokeAsync();
    }

    private string? BuildPluginViewerUrl()
    {
        if (string.IsNullOrWhiteSpace(AgentId) || EntityId == 0)
            return null;

        var parts = new List<string>
        {
            $"agentId={Uri.EscapeDataString(AgentId)}",
            $"entityId={EntityId.ToString(System.Globalization.CultureInfo.InvariantCulture)}",
            "voxels=1",
        };
        if (string.Equals(EntityType, "Grid", StringComparison.OrdinalIgnoreCase))
            parts.Add("context=1");

        return $"{PluginViewerPath}?{string.Join("&", parts)}";
    }
}
